{
	"name": "@victr/favicon-fetcher",
	"version": "4.0.1",
	"author": "Victor Azevedo",
	"description": "Favicon fetcher finds favicons and flawlessly fetches them fast",
	"license": "MIT",
	"keywords": [
		"favicon"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/victrme/favicon-fetcher.git"
	},
	"scripts": {
		"test": "deno test --allow-net --allow-read",
		"demo": "deno run --allow-net --allow-read jsr:@std/http/file-server demo/",
		"dev": "npx wrangler dev ./package/src/index.ts",
		"publish": "tsdown && npm publish --dry-run",
		"build": "tsdown"
	},
	"devDependencies": {
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3"
	},
	"type": "module",
	"files": [
		"/dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	}
}
