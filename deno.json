{
	"$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
	"name": "@victr/favicon-fetcher",
	"version": "4.0.1",
	"license": "MIT",
	"exports": "./package/src/index.ts",
	"nodeModulesDir": "auto",
	"imports": {
		"@std/expect": "jsr:@std/expect@^1.0.19"
	},
	"fmt": {
		"singleQuote": false,
		"semiColons": false,
		"indentWidth": 4,
		"lineWidth": 144,
		"useTabs": true
	},
	"lint": {
		"rules": {
			"tags": [
			  "recommended"
			],
			"include": [
				"default-param-last",
				"eqeqeq",
				"no-eval",
				"no-external-import",
				"no-implicit-declare-namespace-export",
				"no-import-prefix",
				"no-inferrable-types",
				"no-non-null-asserted-optional-chain",
				"no-self-compare",
				"no-slow-types",
				"no-sparse-arrays",
				"no-sync-fn-in-async-fn",
				"no-throw-literal",
				"no-useless-rename",
				"single-var-declarator",
				"prefer-ascii",
				"camelcase",
				"no-non-null-assertion"
			],
			"exclude": [
			  "no-sloppy-imports"
			]
		}
	},
	"unstable": [
		"sloppy-imports"
	],
	"exclude": [
	  ".wrangler"
	]
}
